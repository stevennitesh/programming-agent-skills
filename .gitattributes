* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf
*.md text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.ps1 text eol=lf
*.toml text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
LICENSE text eol=lf

# Raw evaluation outputs preserve exact model-produced bytes, including
# whitespace that would normally be rejected by git diff --check.
docs/validation/evals/review-prompt4/raw/** whitespace=-trailing-space,-blank-at-eof

# Preserve the byte identity of installed active policy baselines.
skills/custom/codebase-design/agents/openai.yaml text eol=crlf
skills/custom/repo-bootstrap/agents/openai.yaml text eol=crlf
skills/custom/skill-router/agents/openai.yaml text eol=crlf
skills/custom/to-tickets/agents/openai.yaml text eol=crlf
